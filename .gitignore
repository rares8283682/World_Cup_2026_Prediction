cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so

# Jupyter
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/
*.env
.env

# OS / editor
.DS_Store
.vscode/
.idea/

# Model artifacts
models/
*.pkl
*.joblib
*.onnx

# Large/generated outputs
outputs/
reports/
artifacts/

# Logs
*.log

# Temporary files
tmp/
temp/
EOF
.Rhistory
FIFA rankings or Elo ratings/
